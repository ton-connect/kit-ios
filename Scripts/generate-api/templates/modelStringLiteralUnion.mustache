{{#nonPublicApi}}internal{{/nonPublicApi}}{{^nonPublicApi}}public{{/nonPublicApi}} enum {{{classname}}}: Codable {
{{#vendorExtensions.x-literal-cases}}
    case {{{name}}}
{{/vendorExtensions.x-literal-cases}}
