{{#vendorExtensions.x-literal-cases}}
        case "{{{rawValue}}}":
            self = .{{{name}}}
{{/vendorExtensions.x-literal-cases}}
        default:
            self = .{{{vendorExtensions.x-ref-case.name}}}(try {{modelNamePrefix}}{{{vendorExtensions.x-ref-case.typeRef}}}(from: decoder))
        }
    }

    {{#nonPublicApi}}internal{{/nonPublicApi}}{{^nonPublicApi}}public{{/nonPublicApi}} func encode(to encoder: any Encoder) throws {
        switch self {
{{#vendorExtensions.x-literal-cases}}
        case .{{{name}}}:
